# AI Provider Configuration
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
AI_PROVIDER=openai  # 'openai' or 'anthropic'

# Database Configuration
DATABASE_URL=sqlite:///dev.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/ai_visibility_api

# Flask Configuration
FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=change-this-in-production
DEBUG=true

# Third-party APIs (optional for search volume data)
DATAFORSEO_API_KEY=your-dataforseo-api-key
DATAFORSEO_API_EMAIL=your-email@example.com

# Application Configuration
LOG_LEVEL=DEBUG
